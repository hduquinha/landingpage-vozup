#############################################
# Instituto UP - Exemplo de Variáveis (.env)
#
# Copie este arquivo para .env.local (dev) ou
# configure estas chaves no painel da Vercel (prod).
# NÃO COMMITAR segredos reais.
#############################################

# === OBRIGATÓRIAS EM PRODUÇÃO (definir na Vercel) ===
# Token de acesso do Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token-here

# Chave pública do Mercado Pago (frontend, Bricks)
VITE_MP_PUBLIC_KEY=TEST-your-public-key-here

# URL pública do frontend (usada em redirecionamentos e imagens do checkout)
FRONTEND_URL=https://instituto-up.vercel.app

# Banco PostgreSQL da API de inscricoes.
# Use uma URL completa:
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco
# Se o servidor exigir SSL, descomente:
# PGSSLMODE=require

# Ou, em vez de DATABASE_URL, use variaveis separadas:
# PGHOST=host-do-banco
# PGPORT=5432
# PGDATABASE=nome_do_banco
# PGUSER=usuario
# PGPASSWORD=senha
# PGSSLMODE=disable

# === OPCIONAIS ===
# Webhook do n8n para adicionar ao Grupo VIP
N8N_WEBHOOK_GRUPO_VIP=https://seu-n8n.webhook.url/grupo-vip

# Webhook do formulário (via backend)
N8N_WEBHOOK_FORM=https://seu-n8n.webhook.url/form

# Webhook do n8n para remarketing (lado do frontend)
VITE_N8N_WEBHOOK_REMARKETING=https://seu-n8n.webhook.url/remarketing

# URL personalizada para notificações do Mercado Pago
NOTIFICATION_URL=https://instituto-up.vercel.app/api/webhook-mercadopago

# URL do backend (opcional). Se NÃO definir, o app usará /api/* (serverless Vercel).
# Defina apenas se for usar um backend externo próprio.
# VITE_BACKEND_URL=

# WhatsApp que receberá os leads da VozUP.
# Use DDI + DDD + número, somente dígitos. Exemplo: 5511999999999
VITE_WHATSAPP_NUMBER=5511999999999

# === SEO / GOOGLE ===
# URL pública final da landing page, sem barra no final.
# Exemplo: https://seudominio.com.br
VITE_SITE_URL=https://seudominio.com.br

# Google Tag Manager. Exemplo: GTM-ABC1234
VITE_GTM_ID=

# Google Analytics 4. Use somente se NÃO for configurar GA4 pelo GTM.
# Exemplo: G-ABC1234567
VITE_GA_MEASUREMENT_ID=

# Token de verificação do Google Search Console, se escolher verificação por meta tag.
VITE_GOOGLE_SITE_VERIFICATION=

# UAZAPI - envie leads pelo backend sem expor token no frontend.
UAZAPI_BASE_URL=https://free.uazapi.com
UAZAPI_INSTANCE_TOKEN=cole-o-token-da-instancia-aqui
UAZAPI_NOTIFY_NUMBER=5511999999999

# Link de inscrição (ex.: Google Forms / Hotmart / Sympla)
VITE_WORKSHOP_LINK=https://example.com/seu-formulario
